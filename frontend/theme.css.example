/* Event-specific theme override. Copy this file to `theme.css` next
 * to style.css and edit. It loads after the bundled stylesheet so
 * any rule here wins.
 *
 * The bundled style.css declares its palette as :root variables, so
 * the most common rebrand is just overriding those:
 */

:root {
  --bg:           #0d1117;
  --surface:      #161b22;
  --border:       #30363d;
  --text:         #c9d1d9;
  --muted:        #8b949e;
  --accent:       #58a6ff;
  --accent-soft:  #1f6feb33;
  --success:      #56d364;
  --success-soft: #2ea04333;
  --danger:       #f85149;
}

/* The site title can take a brand font / colour: */
.brand h1 {
  /* font-family: 'Your Event Display', system-ui, sans-serif; */
  letter-spacing: 0.02em;
}

/* The neutral card background needs slight tuning under a dark palette. */
.card        { background: var(--surface); }
.faucet-banner {
  background: #2d2308;
  border-color: #5a4715;
  color: #ffd784;
}
.faucet-banner strong { color: #ffd784; }
.scoreboard, .receipt, .flag, .instance, .writeup {
  background: #161b22;
}

/* A different challenge-status pill colour is a nice subtle touch: */
.status-solved { color: #4ade80; background: #0d2618; }
