#!/usr/bin/env node
import { argv, env, exit, stdout, stderr } from "node:process";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

function loadDotenv() {
  for (const file of [".env", ".env.local"]) {
    if (!fs.existsSync(file)) continue;
    for (const line of fs.readFileSync(file, "utf8").split("\n")) {
      const m = line.match(/^([A-Z_][A-Z0-9_]*)=(.*)$/);
      if (m && env[m[1]] === undefined) env[m[1]] = m[2].replace(/^['"]|['"]$/g, "");
    }
  }
}
loadDotenv();

const BACKEND = env.BACKEND ?? "http://127.0.0.1:8787";
const TOKEN = env.ADMIN_TOKEN;

const args = argv.slice(2);
const wantJson = args.includes("--json");
const filtered = args.filter(a => a !== "--json");
const cmd = filtered.find(a => !a.startsWith("--"));
const cmdIdx = filtered.indexOf(cmd);
const rest = cmdIdx >= 0 ? filtered.slice(cmdIdx + 1) : [];
const positional = rest.filter((a, i) => {
  if (a.startsWith("--")) return false;
  const prev = rest[i - 1];
  return !(prev && prev.startsWith("--"));
});

if (!cmd || cmd === "help" || cmd === "-h" || cmd === "--help") {
  stdout.write(`ctf-admin — organizer CLI for ctf-blockchain-infra

Usage:
  ctf-admin <command> [args...] [--json]

Commands:
  health                       /api/health
  metrics                      /metrics  (raw Prometheus text)
  config                       /api/config

  instances                    list active private-anvil instances
  kill <challenge> <player>    kill one player's instance
  kill-all                     drain every instance
  solves                       dump the solve tracker

  challenges                   list configured challenges (admin view)
  reload                       hot-reload challenges.json from disk
  drain [on [reason...] | off] pause / resume new private-anvil launches
  writeups [challenge]         dump submitted writeups (optionally one chall)
  smoke <event> <challenge> <player> [solved]
                               send a synthetic webhook event for receiver testing
  smoke-solve <challenge>      run the example solver for <challenge> end-to-end
                               with a throwaway burner. Pre-event smoke test.
                               Requires FAUCET_KEY (defaults to anvil's
                               account 0 when chainId is 31337).
  smoke-solve list             list available smoke recipes (one per
                               examples/<dir>/.ctf-smoke.json).
  smoke-solve all              run every recipe sequentially with isolated
                               burners; prints a pass/fail summary and
                               exits non-zero if anything failed.

  status <challenge> <player>  GET /api/status/:id?address=...
  flag   <challenge> <player>  GET /api/flag/:id?address=...
  sign   <challenge> <player>  GET /api/sign/:id?address=...

  install-pack <dir>           Install a challenge-pack from a directory.
    --target <addr>            fill $INSTALL_TARGET
    --image <ref>              fill $INSTALL_IMAGE
    --fork-url <url>
    --fork-block-number <n>
    --packs-dir <path>         where to write resolved manifest (default ./packs-out/)
    --frontend-dist <path>     where to copy dist/* (default ./frontend/dist/)

Env:
  BACKEND       base URL                       (default ${BACKEND})
  ADMIN_TOKEN   bearer token                   (required for /api/admin/*)
`);
  exit(0);
}

async function api(path, { method = "GET", body = null, headers = {}, admin = false } = {}) {
  const h = { ...headers };
  if (admin) {
    if (!TOKEN) die("ADMIN_TOKEN not set");
    h.authorization = `Bearer ${TOKEN}`;
  }
  if (body) h["content-type"] = "application/json";
  const r = await fetch(`${BACKEND}${path}`, {
    method, headers: h, body: body ? JSON.stringify(body) : undefined,
  });
  const text = await r.text();
  if (!r.ok) die(`${path}: HTTP ${r.status} ${text.slice(0, 200)}`);
  if (path === "/metrics" || h.accept?.startsWith("text/")) return { raw: text };
  try { return JSON.parse(text); }
  catch { return { raw: text }; }
}

let SOFT_FAIL = false;
function die(msg) {
  if (SOFT_FAIL) throw new Error(msg);
  stderr.write(`error: ${msg}\n`);
  exit(1);
}
function out(obj) {
  if (wantJson) stdout.write(JSON.stringify(obj, null, 2) + "\n");
  else stdout.write(typeof obj === "string" ? obj + "\n" : JSON.stringify(obj, null, 2) + "\n");
}

const handlers = {
  async health()    { out(await api("/api/health")); },
  async metrics()   { stdout.write((await api("/metrics")).raw); },
  async config()    { out(await api("/api/config")); },

  async instances() {
    const r = await api("/api/admin/instances", { admin: true });
    if (wantJson) return out(r);
    if (!r.instances?.length) return out("no instances");
    const rows = r.instances.map(i =>
      `${i.challengeId.padEnd(14)} ${i.player.slice(0, 10)}…  exp=${new Date(i.expiresAt * 1000).toISOString().slice(11, 19)}  ${i.rpcUrl}`,
    );
    out(`${r.count} instance(s)\n` + rows.join("\n"));
  },

  async kill() {
    const [ch, player] = positional;
    if (!ch || !player) die("usage: kill <challenge> <player>");
    out(await api(`/api/admin/instances/${ch}/${player}/kill`, { method: "POST", admin: true }));
  },

  async "kill-all"() {
    out(await api("/api/admin/instances/kill-all", { method: "POST", admin: true }));
  },

  async solves() {
    const r = await api("/api/admin/solves", { admin: true });
    if (wantJson) return out(r);
    if (!r.solves?.length) return out("no tracked players");
    const lines = r.solves.map(s =>
      `${s.solved ? "✓" : "·"} ${s.challengeId.padEnd(14)} ${s.player.slice(0, 10)}…  last=${new Date(s.lastSeen * 1000).toISOString().slice(11, 19)}`,
    );
    out(`${r.count} entry(s)\n` + lines.join("\n"));
  },

  async challenges() {
    const r = await api("/api/admin/challenges", { admin: true });
    if (wantJson) return out(r);
    out(r.challenges.map(c =>
      `${c.id.padEnd(14)} mode=${c.mode.padEnd(14)} target=${c.target ?? c.image ?? "?"}` +
      (c.signerEnabled ? `  signer=${c.signerAddress}` : ""),
    ).join("\n"));
  },

  async writeups() {
    const cid = positional[0];
    const r = await api(`/api/admin/writeups${cid ? `?challenge=${cid}` : ""}`, { admin: true });
    if (wantJson) return out(r);
    if (!r.writeups?.length) return out("no writeups");
    for (const w of r.writeups) {
      out(`---\nchallenge: ${w.challenge}\nplayer:    ${w.player}\nts:        ${w.ts}\n\n${w.writeup}\n`);
    }
  },

  async reload() {
    const r = await api("/api/admin/manifest/reload", { method: "POST", admin: true });
    if (wantJson) return out(r);
    out(`reloaded. added=${(r.added ?? []).join(",") || "-"}  removed=${(r.removed ?? []).join(",") || "-"}  total=${r.total}`);
  },

  async drain() {
    const sub = positional[0];
    if (!sub) {
      const r = await api("/api/admin/drain", { admin: true });
      return out(r);
    }
    if (sub === "on") {
      const reason = positional.slice(1).join(" ") || null;
      const r = await api("/api/admin/drain/on", {
        method: "POST", admin: true,
        body: reason ? { reason } : {},
      });
      return out(r);
    }
    if (sub === "off") {
      return out(await api("/api/admin/drain/off", { method: "POST", admin: true }));
    }
    die("usage: drain [on [reason...] | off]");
  },

  async smoke() {
    const [event, challenge, player, solved] = positional;
    if (!event || !challenge || !player) die("usage: smoke <event> <challenge> <player> [solved]");
    out(await api("/api/admin/webhook/test", {
      method: "POST", admin: true,
      body: { event, challenge, player, solved: solved === "true" },
    }));
  },

  async status() {
    const [ch, player] = positional;
    if (!ch || !player) die("usage: status <challenge> <player>");
    out(await api(`/api/status/${ch}?address=${player}`));
  },
  async flag() {
    const [ch, player] = positional;
    if (!ch || !player) die("usage: flag <challenge> <player>");
    out(await api(`/api/flag/${ch}?address=${player}`));
  },
  async sign() {
    const [ch, player] = positional;
    if (!ch || !player) die("usage: sign <challenge> <player>");
    out(await api(`/api/sign/${ch}?address=${player}`));
  },

  async "smoke-solve"() {
    const challengeId = positional[0];
    if (challengeId === "list" || rest.includes("--list")) {
      const recipes = loadSmokeRecipes();
      const rows = Object.entries(recipes)
        .sort(([a], [b]) => a.localeCompare(b))
        .map(([id, r]) => `${id.padEnd(14)} examples/${r.dir}`);
      if (rows.length === 0) return out("no .ctf-smoke.json files found under examples/");
      return out(`${rows.length} recipe(s):\n` + rows.join("\n"));
    }
    if (challengeId === "all" || rest.includes("--all")) {
      const recipes = loadSmokeRecipes();
      const ids = Object.keys(recipes).sort();
      if (ids.length === 0) die("no .ctf-smoke.json files found under examples/");
      const results = [];
      SOFT_FAIL = true;
      for (const id of ids) {
        process.stdout.write(`\n=== smoke-solve ${id} ===\n`);
        try {
          await smokeSolve(id);
          results.push([id, true, null]);
        } catch (e) {
          results.push([id, false, e.message ?? String(e)]);
          stderr.write(`✗ ${id}: ${e.message ?? e}\n`);
        }
      }
      SOFT_FAIL = false;
      process.stdout.write(`\n=== summary ===\n`);
      const passed = results.filter(r => r[1]).length;
      for (const [id, ok_, err] of results) {
        process.stdout.write(`${ok_ ? "✓" : "✗"} ${id.padEnd(14)}${err ? "  " + err : ""}\n`);
      }
      process.stdout.write(`\n${passed}/${results.length} passed\n`);
      exit(passed === results.length ? 0 : 1);
    }
    if (!challengeId) die("usage: smoke-solve <challenge> | smoke-solve list | smoke-solve all");
    await smokeSolve(challengeId);
  },

  async "install-pack"() {
    const [packDir, ...flags] = rest;
    if (!packDir) die("usage: install-pack <dir> [--target <addr>] [--image <ref>] ...");
    const opts = parseFlags(flags);
    await installPack(path.resolve(packDir), opts);
  },
};

function loadSmokeRecipes() {
  const here = path.dirname(fileURLToPath(import.meta.url));
  const examples = path.resolve(here, "..", "examples");
  const recipes = {};
  if (!fs.existsSync(examples)) return recipes;
  for (const ent of fs.readdirSync(examples, { withFileTypes: true })) {
    if (!ent.isDirectory()) continue;
    const recipePath = path.join(examples, ent.name, ".ctf-smoke.json");
    if (!fs.existsSync(recipePath)) continue;
    let data;
    try { data = JSON.parse(fs.readFileSync(recipePath, "utf8")); }
    catch (e) { stderr.write(`  warn: ${recipePath} invalid JSON: ${e.message}\n`); continue; }
    if (data.spec && data.spec !== "ctf-smoke/v1") {
      stderr.write(`  warn: ${recipePath} unsupported spec ${data.spec}\n`);
      continue;
    }
    if (!data.challengeId) {
      stderr.write(`  warn: ${recipePath} missing challengeId\n`);
      continue;
    }
    recipes[data.challengeId] = {
      dir: ent.name,
      fromInfo:   data.fromInfo   ?? {},
      extra:      data.extra      ?? {},
      fundTokens: data.fundTokens ?? {},
    };
  }
  return recipes;
}

async function smokeSolve(challengeId) {
  const recipes = loadSmokeRecipes();
  const recipe = recipes[challengeId];
  if (!recipe) {
    const known = Object.keys(recipes).sort().join(", ") || "(none)";
    die(`no smoke recipe for ${challengeId}; known: ${known}\n` +
        `add examples/<dir>/.ctf-smoke.json with the right challengeId`);
  }

  const cfg = await api("/api/config");
  const ch  = cfg.challenges.find(c => c.id === challengeId);
  if (!ch) die(`challenge ${challengeId} not in /api/config`);

  const ethers = await loadEthersFromExamples();
  const burner = ethers.Wallet.createRandom();
  console.log(`burner: ${burner.address}`);

  const fundingKey = process.env.FAUCET_KEY ?? process.env.SMOKE_FUNDING_KEY
                   ?? (cfg.chainId === 31337
                       ? "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
                       : null);
  if (!fundingKey) die("FAUCET_KEY env required (or set SMOKE_FUNDING_KEY)");
  const rpc = process.env.RPC_URL ?? cfg.rpcUrl;
  const provider = new ethers.JsonRpcProvider(rpc);
  const funder   = new ethers.Wallet(fundingKey, provider);
  const value    = ethers.parseEther(process.env.SMOKE_FUNDING_ETH ?? "0.05");
  let nonce      = await funder.getNonce();
  const tx = await funder.sendTransaction({ to: burner.address, value, nonce: nonce++ });
  await tx.wait();
  console.log(`funded ${ethers.formatEther(value)} ETH from ${funder.address}`);

  const solverEnv = {};
  for (const [envKey, label] of Object.entries(recipe.fromInfo)) {
    const row = (ch.info ?? []).find(r => r.label === label);
    if (!row) die(`/api/config[${challengeId}].info missing row labelled "${label}"`);
    solverEnv[envKey] = row.value;
  }
  Object.assign(solverEnv, recipe.extra ?? {});

  for (const [label, amountWei] of Object.entries(recipe.fundTokens ?? {})) {
    const row = (ch.info ?? []).find(r => r.label === label);
    if (!row) die(`fundTokens references missing info label "${label}"`);
    const erc20 = new ethers.Contract(row.value, [
      "function transfer(address,uint256) returns (bool)",
      "function balanceOf(address) view returns (uint256)",
    ], funder);
    const funderBal = await erc20.balanceOf(funder.address);
    if (funderBal < BigInt(amountWei)) {
      die(`funder lacks ${amountWei} of ${row.value} (has ${funderBal.toString()})`);
    }
    const ttx = await erc20.transfer(burner.address, amountWei, { nonce: nonce++ });
    await ttx.wait();
    console.log(`funded ${amountWei} of token ${row.value.slice(0, 10)}…`);
  }

  const { spawn } = await import("node:child_process");
  const solverPath = path.resolve(
    path.dirname(fileURLToPath(import.meta.url)),
    "..", "examples", recipe.dir, "solver", "solve.js",
  );
  const env = {
    ...process.env,
    PLAYER_KEY: burner.privateKey,
    BACKEND:    BACKEND,
    CHALLENGE:  challengeId,
    RPC_URL:    rpc,
    ...solverEnv,
  };
  console.log(`running ${solverPath}`);
  const child = spawn(process.execPath, [solverPath], { env, stdio: "inherit" });
  const code = await new Promise(r => child.on("close", r));
  if (code !== 0) die(`solver exited ${code}`, code);
  console.log("\nsmoke-solve OK");
}

async function loadEthersFromExamples() {
  // Examples node_modules ships ethers; reuse it so this script has zero deps of its own.
  const { createRequire } = await import("node:module");
  const { pathToFileURL } = await import("node:url");
  const here = path.dirname(fileURLToPath(import.meta.url));
  const examplesReq = createRequire(path.join(here, "..", "examples", "package.json"));
  try {
    const ethersMain = examplesReq.resolve("ethers");
    return (await import(pathToFileURL(ethersMain).href)).ethers;
  } catch {
    die("ethers not found — run `npm install` in the examples/ directory");
  }
}

function parseFlags(arr) {
  const o = {};
  for (let i = 0; i < arr.length; i++) {
    const a = arr[i];
    if (!a.startsWith("--")) continue;
    const k = a.slice(2);
    o[k] = arr[i + 1];
    i++;
  }
  return o;
}

async function installPack(packDir, opts) {
  if (!fs.existsSync(packDir)) die(`pack dir not found: ${packDir}`);
  const packYamlPath = path.join(packDir, "pack.yaml");
  if (!fs.existsSync(packYamlPath)) die(`missing pack.yaml in ${packDir}`);

  const pack = parseMiniYaml(fs.readFileSync(packYamlPath, "utf8"));
  if (pack.spec !== "ctf-pack/v1") die(`unsupported pack spec: ${pack.spec ?? "(none)"}`);
  if (!pack.id || !/^[a-z0-9_-]{1,32}$/i.test(pack.id)) die(`pack.yaml: invalid id ${pack.id}`);

  const manifestPath = path.join(packDir, "manifest.json");
  if (!fs.existsSync(manifestPath)) die(`missing manifest.json in ${packDir}`);
  let manifestText = fs.readFileSync(manifestPath, "utf8");

  const subs = {
    INSTALL_TARGET: opts.target,
    INSTALL_IMAGE: opts.image,
    INSTALL_FORK_URL: opts["fork-url"],
    INSTALL_FORK_BLOCK: opts["fork-block-number"],
  };
  for (const f of pack.install?.resolveFields ?? []) {
    const envKey = `INSTALL_${f.replace(/\W/g, "_").toUpperCase()}`;
    if (!subs[envKey]) die(`pack requires ${f}; pass --${f.replace(/\./g, "-")}=...`);
  }
  for (const [k, v] of Object.entries(subs)) {
    if (v == null) continue;
    manifestText = manifestText.replaceAll(`$${k}`, v);
  }
  let manifest;
  try { manifest = JSON.parse(manifestText); }
  catch (e) { die(`resolved manifest is not valid JSON: ${e.message}`); }

  const packsDir = path.resolve(opts["packs-dir"] ?? "packs-out");
  const frontDist = path.resolve(opts["frontend-dist"] ?? "frontend/dist");
  fs.mkdirSync(packsDir, { recursive: true });
  fs.mkdirSync(path.join(frontDist, pack.id), { recursive: true });

  const outManifest = path.join(packsDir, `${pack.id}.json`);
  fs.writeFileSync(outManifest, JSON.stringify(manifest, null, 2) + "\n");

  const distSrc = path.join(packDir, "dist");
  let copied = 0;
  if (fs.existsSync(distSrc)) {
    for (const f of fs.readdirSync(distSrc)) {
      const src = path.join(distSrc, f);
      const dst = path.join(frontDist, pack.id, f);
      fs.copyFileSync(src, dst);
      copied++;
    }
  }

  out(`installed pack ${pack.id}\n` +
    `  manifest: ${outManifest}\n` +
    `  dist files copied: ${copied} → ${path.join(frontDist, pack.id)}\n` +
    `  required env vars: ${(pack.requires?.env ?? []).join(", ") || "(none)"}\n` +
    `\nnext: splice ${outManifest} into your challenges.json, then \`ctf-admin reload\`.`);
}

function parseMiniYaml(text) {
  const root = {};
  const stack = [{ obj: root, indent: -1 }];
  const lines = text.split("\n");
  let pendingMulti = null;
  let pendingIndent = 0;
  for (let raw of lines) {
    if (pendingMulti) {
      if (raw.length === 0 || (raw.match(/^ +/) && raw.match(/^ +/)[0].length >= pendingIndent)) {
        pendingMulti.value += (pendingMulti.value ? "\n" : "") + raw.slice(pendingIndent);
        continue;
      }
      pendingMulti.parent[pendingMulti.key] = pendingMulti.value;
      pendingMulti = null;
    }
    const trimmed = raw.replace(/#.*/, "").trimEnd();
    if (!trimmed.trim()) continue;
    const indent = raw.match(/^ */)[0].length;
    while (stack.length > 1 && indent <= stack[stack.length - 1].indent) stack.pop();
    const cur = stack[stack.length - 1].obj;
    const ms = trimmed.trim();
    if (ms.startsWith("- ")) {
      if (!Array.isArray(cur._items)) cur._items = [];
      cur._items.push(ms.slice(2).trim().replace(/^["']|["']$/g, ""));
      continue;
    }
    const colon = ms.indexOf(":");
    if (colon === -1) continue;
    const key = ms.slice(0, colon).trim();
    const val = ms.slice(colon + 1).trim();
    if (val === "" || val === "|") {
      if (val === "|") {
        pendingMulti = { parent: cur, key, value: "" };
        pendingIndent = indent + 2;
      } else {
        const child = {};
        cur[key] = child;
        stack.push({ obj: child, indent });
      }
    } else {
      cur[key] = val.replace(/^["']|["']$/g, "");
    }
  }
  if (pendingMulti) pendingMulti.parent[pendingMulti.key] = pendingMulti.value;
  return collapseArrays(root);
}

function collapseArrays(obj) {
  if (Array.isArray(obj)) return obj.map(collapseArrays);
  if (obj && typeof obj === "object") {
    if (Array.isArray(obj._items)) return obj._items;
    const out = {};
    for (const [k, v] of Object.entries(obj)) out[k] = collapseArrays(v);
    return out;
  }
  return obj;
}

const handler = handlers[cmd];
if (!handler) die(`unknown command: ${cmd}`);
try { await handler(); }
catch (e) { die(e.message ?? String(e)); }
