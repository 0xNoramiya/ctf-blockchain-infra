# Root .env.example — used by the standalone scripts in `deploy/`.
# The backend reads its own .env (see backend/.env.example).

# Domain that points at this VPS via Cloudflare (proxied A record).
PUBLIC_DOMAIN=ctf.example.com

# Nginx public-facing port. Cloudflare's Origin Rule overrides destination
# port to match this. 8080 keeps you out of port 80/443 conflicts.
NGINX_PORT=8080
